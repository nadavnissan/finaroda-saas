# FINARODA SaaS — backend environment variables (names only; no secrets here).
# Copy to backend/.env (or .env.local for dev overrides) and fill values.

# ── General ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
BASE_URL=http://localhost:3000
API_URL=http://localhost:8000
ADMIN_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
DATABASE_URL=data/finaroda.db

# ── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=
JWT_EXPIRE_DAYS=30
MAGIC_LINK_EXPIRE_MINUTES=15
OAUTH_STATE_TTL_MINUTES=10
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
ADMIN_USER_IDS=
FEATURE_PUBLIC_SIGNUPS_OPEN=false

# ── Storage / R2 ─────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=_local_storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT_URL=
R2_BUCKET_ACADEMY=finaroda-academy
R2_BUCKET_DB_BACKUP=finaroda-db-backup
R2_PUBLIC_URL_ACADEMY=

# ── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_KEY=

# ── Email (Resend, transactional) ───────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM_BRAND=
EMAIL_REPLY_TO=
EMAIL_SENDING_ENABLED=false
DEV_RETURN_MAGIC_LINK=false

# ── Trial ────────────────────────────────────────────────────────────────────
TRIAL_DAYS=14

# ── Cardcom v11 (sole payment provider) ──────────────────────────────────────
FEATURE_CARDCOM_LIVE=false
CARDCOM_TERMINAL_ID=
CARDCOM_TEST_TERMINAL=1000
CARDCOM_API_NAME=
CARDCOM_API_PASSWORD=
CARDCOM_WEBHOOK_SECRET=
CARDCOM_BASE_URL=https://secure.cardcom.solutions/api/v11
CARDCOM_REDIRECT_RETURN_URL=

# ── Scan engine ──────────────────────────────────────────────────────────────
BYBIT_PUBLIC_BASE_URL=https://api.bybit.com/v5/market
DEFAULT_SCAN_THRESHOLD=70.0

# ── Monitoring / Sentry ──────────────────────────────────────────────────────
SENTRY_DSN_BACKEND=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=
