# ==============================================================================
# FINARODA backend — PRODUCTION env template (Railway).
# Names + safe production DEFAULTS only. NEVER commit a real secret value here.
# Set the real values in the Railway dashboard (Variables tab). This file is the
# checklist you copy from. `<fill>` = you must provide a value before go-live.
#
# Local development uses backend/.env.example instead (DEV_RETURN_MAGIC_LINK=true etc.).
# ==============================================================================

# ── General / domains (D3 wiring) ────────────────────────────────────────────
# Domain scheme (repo convention, OPEN_ITEMS: domain = FINARODA.COM):
#   frontend (Vercel) → https://finaroda.com   (apex, canonical; www 308-redirects to it)
#   backend  (Railway) → https://api.finaroda.com  (custom domain; or the *.up.railway.app URL)
# CORS allow-list is built from BASE_URL + ADMIN_URL + FRONTEND_URL (main.py). The admin
# console is a route in the SAME frontend app, so ADMIN_URL = the frontend origin.
ENVIRONMENT=production
LOG_LEVEL=INFO
BASE_URL=https://finaroda.com
FRONTEND_URL=https://finaroda.com
ADMIN_URL=https://finaroda.com
API_URL=https://api.finaroda.com
# SQLite file on the mounted Railway volume (mount a volume at /app/data). Litestream
# replicates it to R2 (see litestream.yml + the R2_* vars below).
DATABASE_URL=data/finaroda.db

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# REQUIRED. Empty in production → the app refuses to boot. Generate: openssl rand -hex 32
JWT_SECRET=<fill>
JWT_EXPIRE_DAYS=30
MAGIC_LINK_EXPIRE_MINUTES=15
OAUTH_STATE_TTL_MINUTES=10
# Google/Apple sign-in (optional; empty GOOGLE_CLIENT_ID makes prod OAuth verify hard-fail
# only if a user actually attempts Google sign-in — magic-link works without these).
GOOGLE_CLIENT_ID=<fill-if-using-google-signin>
GOOGLE_CLIENT_SECRET=<fill-if-using-google-signin>
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
# Auto-granted admin on signup (bootstrap the first admin). Comma-separated.
ADMIN_BOOTSTRAP_EMAILS=rodanis@gmail.com
# Closed beta by default (only allowlisted emails sign up). Flip to true at public launch.
FEATURE_PUBLIC_SIGNUPS_OPEN=false
# F17 Arena — lawyer-gated. Keep false until cleared.
FEATURE_ARENA=false

# ── CRITICAL production guard (Stage 8) ──────────────────────────────────────
# MUST be false in production. true returns the magic link in the API response, which
# bypasses email possession → account takeover. main.py refuses to boot if this is true
# while ENVIRONMENT=production (asserted by test_production_guard.py).
DEV_RETURN_MAGIC_LINK=false

# ── Encryption ───────────────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<fill>

# ── Email (Resend) ───────────────────────────────────────────────────────────
# Live sending needs finaroda.com verified in Resend (SPF/DKIM). Until then leave
# RESEND_API_KEY empty → emails are logged, not sent (safe DEV fallback).
RESEND_API_KEY=<fill-after-domain-verified>
EMAIL_SENDING_ENABLED=true
EMAIL_FROM_BRAND=FINARODA <noreply@finaroda.com>
EMAIL_REPLY_TO=support@finaroda.com

# ── Cron (Stage 5/3R scheduled sweeps) ───────────────────────────────────────
# Shared secret for POST /api/cron/notifications and /api/cron/billing (X-Cron-Secret
# header). Empty → those endpoints return 503 (fail closed). Generate: openssl rand -hex 32
CRON_SECRET=<fill>

# ── Trial ────────────────────────────────────────────────────────────────────
TRIAL_DAYS=14
TRIAL_REMINDER_LEAD_DAYS=3

# ── Billing / Stripe (Checkout + Billing) ────────────────────────────────────
# Go live is a MANUAL, lawyer-gated step (see the STRIPE GO-LIVE box in SESSION_HANDOFF).
# Ship with FEATURE_STRIPE_LIVE=false + TEST keys (sk_test_...): checkout runs against
# Stripe test mode, no real charges. Flip to true + live keys only after go-live checklist.
FEATURE_STRIPE_LIVE=false
STRIPE_SECRET_KEY=sk_test_<fill>
STRIPE_PUBLISHABLE_KEY=pk_test_<fill>
STRIPE_WEBHOOK_SECRET=whsec_<fill>
STRIPE_SUCCESS_PATH=/checkout/success
STRIPE_CANCEL_PATH=/checkout/cancelled
BILLING_PERIOD_DAYS=30
# Israeli tax-invoice provider: mock (offline doc) until the accountant picks one
# (green_invoice | icount | ezcount). Stripe invoices are NOT Israeli tax documents.
INVOICE_PROVIDER=mock

# ── Storage / Cloudflare R2 (SQLite backup + academy assets) ─────────────────
STORAGE_BACKEND=r2
LOCAL_STORAGE_PATH=_local_storage
R2_ACCOUNT_ID=<fill>
R2_ACCESS_KEY_ID=<fill>
R2_SECRET_ACCESS_KEY=<fill>
R2_ENDPOINT_URL=
R2_BUCKET_ACADEMY=finaroda-academy
R2_BUCKET_DB_BACKUP=finaroda-db-backup
R2_PUBLIC_URL_ACADEMY=

# ── Scan engine ──────────────────────────────────────────────────────────────
BYBIT_PUBLIC_BASE_URL=https://api.bybit.com/v5/market
DEFAULT_SCAN_THRESHOLD=70.0

# ── Monitoring / Sentry (optional; empty = disabled, zero network) ───────────
SENTRY_DSN_BACKEND=<fill-optional>
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_RELEASE=
