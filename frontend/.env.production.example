# ==============================================================================
# FINARODA frontend — PRODUCTION env template (Vercel).
# Set these in the Vercel dashboard (Project → Settings → Environment Variables,
# scope = Production). NEXT_PUBLIC_* values are inlined into the client bundle at
# build time, so they are PUBLIC — never put a secret in a NEXT_PUBLIC_ var.
# Local development uses frontend/.env.local (NEXT_PUBLIC_API_URL=http://localhost:8000).
# ==============================================================================

# Backend API origin (Railway). Must match the backend's public domain and be included
# in the backend CORS allow-list (BASE_URL/FRONTEND_URL/ADMIN_URL). The browser calls
# this cross-origin with credentials (httpOnly cookie), so it must be an exact origin.
NEXT_PUBLIC_API_URL=https://api.finaroda.com

# F17 Arena mirror — keep false until lawyer clearance (mirrors backend FEATURE_ARENA).
NEXT_PUBLIC_FEATURE_ARENA=false

# Sentry (optional). Empty → frontend Sentry disabled, zero network. To activate: set the
# DSN AND ensure @sentry/nextjs is installed at build (pnpm install pulls it).
NEXT_PUBLIC_SENTRY_DSN=

# NOTE — domain / www: set finaroda.com as the Vercel primary domain and let
# www.finaroda.com 308-redirect to it (Vercel domain settings). The app always loads on
# the apex origin, so the backend CORS allow-list only needs https://finaroda.com.
